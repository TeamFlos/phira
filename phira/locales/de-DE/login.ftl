action-success =
    { $action ->
        [login] Anmeldung erfolgreich
        [register] Registrierung erfolgreich
        [hykb-login] 3839-Games-Anmeldung erfolgreich
       *[andere] _
    }
action-failed =
    { $action ->
        [login] Fehler beim Anmelden.
        [register] Fehler beim Registrieren.
        [hykb-login] 3839-Games-Anmeldung fehlgeschlagen
       *[andere] _
    }
email-sent = Bitte prüfe in deinem Posteingang auf eine Aktivierungs-E-Mail von Phira
